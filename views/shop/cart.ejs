<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <%- include('../partials/flash') %>

    <div class="page-header mb-4">
      <h1>Shopping Cart</h1>
    </div>

    <% if (cartItems && cartItems.length > 0) { %>
      <div class="table cart-table">
        <div class="table-header flex gap-4">
          <div style="flex: 3;">Product</div>
          <div style="flex: 1;">Price</div>
          <div style="flex: 2;">Quantity</div>
          <div style="flex: 1;">Total</div>
          <div style="flex: 1;">Action</div>
        </div>

        <% cartItems.forEach(function(item) { %>
          <div class="table-row flex gap-4 flex-center">
            <div style="flex: 3;">
              <a href="/products/<%= item.slug %>"><%= item.name %></a>
            </div>
            <div style="flex: 1;">
              $<%= Number(item.price).toFixed(2) %>
            </div>
            <div style="flex: 2;">
              <form action="/cart/update" method="POST" class="flex gap-2" style="align-items: center;">
                <input type="hidden" name="item_id" value="<%= item.id %>">
                <input type="number" name="quantity" value="<%= item.quantity %>" min="1" class="form-input" style="width: 70px;">
                <button type="submit" class="btn btn-sm btn-outline">Update</button>
              </form>
            </div>
            <div style="flex: 1;">
              $<%= Number(item.price * item.quantity).toFixed(2) %>
            </div>
            <div style="flex: 1;">
              <form action="/cart/remove" method="POST">
                <input type="hidden" name="item_id" value="<%= item.id %>">
                <button type="submit" class="btn btn-sm btn-danger">Remove</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>

      <div class="total-row text-right mt-4">
        <h3>Order Total: $<%= Number(total).toFixed(2) %></h3>
      </div>

      <div class="flex gap-3 mt-4">
        <a href="/checkout" class="btn btn-primary">Proceed to Checkout</a>
        <a href="/products" class="btn btn-outline">Continue Shopping</a>
      </div>
    <% } else { %>
      <div class="text-center mt-8">
        <p>Your cart is empty</p>
        <a href="/products" class="btn btn-primary mt-2">Browse Products</a>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
