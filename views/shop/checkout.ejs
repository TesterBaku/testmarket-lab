<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <%- include('../partials/flash') %>

    <div class="page-header mb-4">
      <h1>Checkout</h1>
    </div>

    <div class="grid grid-2 gap-4">
      <div class="card">
        <div class="card-body">
          <h2>Shipping Information</h2>
          <form action="/checkout" method="POST" class="mt-3">
            <div class="form-group">
              <label class="form-label" for="shipping_name">Shipping Name</label>
              <input type="text" name="shipping_name" id="shipping_name" class="form-input" required>
            </div>

            <div class="form-group mt-3">
              <label class="form-label" for="shipping_address">Shipping Address</label>
              <input type="text" name="shipping_address" id="shipping_address" class="form-input" required>
            </div>

            <div class="form-group mt-3">
              <label class="form-label" for="shipping_city">Shipping City</label>
              <input type="text" name="shipping_city" id="shipping_city" class="form-input" required>
            </div>

            <div class="form-group mt-3">
              <label class="form-label" for="shipping_zip">Shipping Zip Code</label>
              <input type="text" name="shipping_zip" id="shipping_zip" class="form-input" required>
            </div>

            <button type="submit" class="btn btn-primary mt-4">Place Order</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <h2>Order Summary</h2>
          <p class="mt-3">You'll be charged based on your cart total</p>
          <div class="mt-4">
            <a href="/cart" class="btn btn-outline">&larr; Back to Cart</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
