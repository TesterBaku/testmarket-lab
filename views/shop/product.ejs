<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <%- include('../partials/flash') %>

    <div class="page-header mb-4">
      <a href="/products" class="btn btn-outline mb-2">&larr; Back to Products</a>
    </div>

    <% if (product) { %>
      <div class="grid grid-2 gap-4">
        <!-- Left Column: Product Info -->
        <div class="card">
          <div class="card-body">
            <h1><%= product.name %></h1>

            <% if (product.image_url) { %>
              <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image mt-2 mb-2" style="max-width: 100%;">
            <% } %>

            <p class="mt-2"><%= product.description %></p>

            <div class="flex gap-2 mt-3">
              <span class="badge badge-info"><%= product.category %></span>
              <% if (product.stock > 0) { %>
                <span class="badge badge-success">In Stock (<%= product.stock %> available)</span>
              <% } else { %>
                <span class="badge badge-danger">Out of Stock</span>
              <% } %>
            </div>

            <p class="price mt-3" style="font-size: 1.5rem; font-weight: bold;">$<%= Number(product.price).toFixed(2) %></p>
          </div>
        </div>

        <!-- Right Column: Add to Cart -->
        <div class="card">
          <div class="card-body">
            <h2>Add to Cart</h2>
            <% if (product.stock > 0) { %>
              <form action="/cart/add" method="POST" class="mt-3">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <div class="form-group">
                  <label class="form-label" for="quantity">Quantity</label>
                  <input type="number" name="quantity" id="quantity" class="form-input" value="1" min="1" max="<%= product.stock %>">
                </div>
                <button type="submit" class="btn btn-primary mt-2">Add to Cart</button>
              </form>
            <% } else { %>
              <p class="alert alert-error mt-3">This product is currently out of stock.</p>
            <% } %>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="text-center mt-8">
        <p>Product not found.</p>
        <a href="/products" class="btn btn-outline mt-2">Browse Products</a>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
