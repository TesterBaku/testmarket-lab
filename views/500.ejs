<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<main class="container">
  <div class="card" style="max-width: 500px; margin: 3rem auto; text-align: center;">
    <div class="card-body">
      <h1 style="font-size: 3rem; margin-bottom: 0.5rem;">500</h1>
      <h2>Server Error</h2>
      <p style="margin: 1rem 0;">Something went wrong on our end. Please try again later.</p>
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-error" style="text-align: left; margin: 1rem 0;">
          <strong>Error Details:</strong>
          <p style="margin-top: 0.5rem; font-family: monospace; font-size: 0.9rem;"><%= message %></p>
        </div>
      <% } %>
      <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
</body>
</html>
