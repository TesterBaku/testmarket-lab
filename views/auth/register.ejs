<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>
<main class="container">
  <%- include('../partials/flash') %>
  <div class="card" style="max-width: 400px; margin: 2rem auto;">
    <div class="card-body">
      <h2 class="text-center" style="margin-bottom: 1.5rem;">Create Account</h2>
      <form action="/auth/register" method="POST">
        <div class="form-group">
          <label class="form-label" for="name">Name</label>
          <input class="form-input" type="text" id="name" name="name" required autocomplete="name">
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" type="password" id="password" name="password" required minlength="6" autocomplete="new-password">
          <p class="form-error" style="font-size: 0.85rem; margin-top: 0.25rem;">Minimum 6 characters</p>
        </div>
        <button type="submit" data-testid="register-submit" class="btn btn-primary" style="width: 100%; margin-top: 0.5rem;">Create Account</button>
      </form>
      <p class="text-center" style="margin-top: 1rem;">
        Already have an account? <a href="/auth/login">Log In</a>
      </p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
