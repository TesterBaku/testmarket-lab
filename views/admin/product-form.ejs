<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>
<main class="container">
  <%- include('../partials/flash') %>
  <div class="page-header">
    <h1><%= product ? 'Edit Product' : 'New Product' %></h1>
  </div>

  <div class="card" style="max-width: 600px;">
    <div class="card-body">
      <form action="<%= product ? '/admin/products/' + product.id + '/edit' : '/admin/products' %>" method="POST">
        <div class="form-group">
          <label class="form-label" for="name">Name</label>
          <input class="form-input" type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="price">Price</label>
          <input class="form-input" type="number" id="price" name="price" step="0.01" min="0" value="<%= product ? product.price : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="category">Category</label>
          <input class="form-input" type="text" id="category" name="category" value="<%= product ? product.category : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="stock">Stock</label>
          <input class="form-input" type="number" id="stock" name="stock" min="0" value="<%= product ? product.stock : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="description">Description</label>
          <textarea class="form-input" id="description" name="description" rows="5"><%= product ? product.description : '' %></textarea>
        </div>
        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
          <button type="submit" class="btn btn-primary"><%= product ? 'Update Product' : 'Create Product' %></button>
          <% if (product) { %>
            <a href="/admin/products" class="btn btn-outline">Cancel</a>
          <% } %>
        </div>
      </form>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
